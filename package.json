{
  "name": "color-guide",
  "version": "1.0.0",
  "description": "Style Guide Extractor API using Fastify + Playwright",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
